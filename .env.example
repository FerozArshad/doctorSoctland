# ── Core ────────────────────────────────────────────────────────────────
# REMOTE POSTGRES ONLY — copy Production values from Vercel → Settings → Environment Variables.
# Local dev and production share the same database.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Long random string — used to sign login session cookies. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Public URL of the app (local dev can still use localhost; proposal links use this in emails)
APP_URL="http://localhost:3000"

# ── Stripe (dashboard.stripe.com → Developers → API keys) ──────────────
STRIPE_SECRET_KEY="sk_test_..."
# From Dashboard → Webhooks endpoint secret (production)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (resend.com → API keys; verify dentalscotland.com domain) ────
RESEND_API_KEY=""
EMAIL_FROM="Dental Scotland <concierge@dentalscotland.com>"

# ── WhatsApp Business Cloud API (developers.facebook.com) ──────────────
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ── Practice / notifications ────────────────────────────────────────────
ADMIN_NOTIFY_EMAIL="concierge@dentalscotland.com"
ADMIN_NOTIFY_WHATSAPP=""

# ── Finance & pricing ───────────────────────────────────────────────────
FINANCE_APPLY_URL="https://your-finance-provider.example.com/apply"
PAY_DISCOUNT_PCT="5"

# ── Cron (protects instalment collection + live seed endpoint) ───────────
CRON_SECRET="change-me-too"

# ── Gmail send (Google Cloud OAuth; scope gmail.send) ────────────────────
# Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application).
# Authorized redirect URI: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Obtained once by visiting /api/auth/google as an admin (leave blank until then).
GMAIL_REFRESH_TOKEN=""
