# ── Core ────────────────────────────────────────────────────────────────
# SQLite for local dev. Production: postgres://... (and set provider in schema.prisma)
DATABASE_URL="file:./dev.db"
# Long random string — used to sign login session cookies. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Public URL of the app (used in emailed/WhatsApp'd proposal links)
APP_URL="http://localhost:3000"

# ── Stripe (dashboard.stripe.com → Developers → API keys) ──────────────
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook` (dev)
# or Dashboard → Webhooks endpoint secret (production)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (resend.com → API keys; verify dentalscotland.com domain) ────
RESEND_API_KEY=""
EMAIL_FROM="Dental Scotland <smile@dentalscotland.com>"

# ── WhatsApp Business Cloud API (developers.facebook.com) ──────────────
# Meta app → WhatsApp → API Setup: permanent access token + phone number ID
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ── Practice / notifications ────────────────────────────────────────────
# Where "patient is interested" / payment alerts are sent
ADMIN_NOTIFY_EMAIL="reception@dentalscotland.com"
# E.164 format, e.g. +447700900000 — admin WhatsApp alerts
ADMIN_NOTIFY_WHATSAPP=""

# ── Finance & pricing ───────────────────────────────────────────────────
# Your external 0% finance provider's application link (Tabeo/Chrysalis/etc.)
FINANCE_APPLY_URL="https://your-finance-provider.example.com/apply"
# Pay-in-full discount percentage
PAY_DISCOUNT_PCT="5"

# ── Cron (protects the instalment collection endpoint) ─────────────────
CRON_SECRET="change-me-too"
