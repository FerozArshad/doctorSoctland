// Dental Scotland — Invisalign proposal & payment system
// Remote Postgres only (Vercel Postgres / Neon / Supabase).
// Local dev uses the SAME DATABASE_URL as production — copy from Vercel → .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Practice-wide pricing, editable by admins. Single row (id = "default").
/// Patients keep their own pricePence/discountPct captured at proposal time,
/// so changing these only affects NEW/edited proposals — never existing charges.
model Pricing {
  id               String   @id @default("default")
  tier1MaxAligners Int      @default(7)
  tier1Pence       Int      @default(150000)
  tier2MaxAligners Int      @default(20)
  tier2Pence       Int      @default(225000)
  tier3Pence       Int      @default(275000)
  depositPence     Int      @default(70000)
  upfrontPence     Int      @default(25000)
  discountPct      Int      @default(5)
  updatedAt        DateTime @updatedAt
  updatedByEmail   String   @default("")
}

/// WhatsApp Cloud API credentials — Super Admin edits in /admin/whatsapp.
/// Shared DB means local + production both use the same live connection.
/// Empty fields fall back to process.env (Vercel) for migration.
model WhatsAppSettings {
  id                   String   @id @default("default")
  token                String   @default("")
  phoneNumberId        String   @default("")
  templatesEnabled     Boolean  @default(false)
  templateLang         String   @default("en_GB")
  tplProposal          String   @default("payment_reminder")
  tplReminder          String   @default("porposal_ready")
  tplLogin             String   @default("login_code")
  webhookVerifyToken   String   @default("")
  metaAppSecret        String   @default("")
  adminNotifyWhatsApp  String   @default("")
  updatedAt            DateTime @updatedAt
  updatedByEmail       String   @default("")
}

model Admin {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  role         String          @default("Treatment Coordinator")
  // Super Admin sees revenue/earnings and ALL patients; a plain Admin sees only
  // the patients they own (or sent), and no revenue.
  isSuperAdmin Boolean         @default(false)
  // Notification bell: keys like "up:patientId:touch" / "sent:activityId"
  notifReadKeys      String[] @default([])
  notifDismissedKeys String[] @default([])
  createdAt    DateTime        @default(now())
  patients     Patient[]
  reports      MonthlyReport[]
}

/// Monthly performance report per admin. Invisalign orders & income are computed
/// live from the admin's patients/payments — these fields hold the manually
/// entered consult and bonding/veneer numbers. One row per admin per month.
model MonthlyReport {
  id                 String   @id @default(cuid())
  adminId            String
  admin              Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  year               Int
  month              Int // 1-12
  consultsSeen       Int      @default(0) // Invisalign consults seen
  consultsProceeded  Int      @default(0) // ...that went ahead
  bondingConsults    Int      @default(0)
  bondingProceeded   Int      @default(0)
  bondingIncomePence Int      @default(0)
  veneerConsults     Int      @default(0)
  veneerProceeded    Int      @default(0)
  veneerIncomePence  Int      @default(0)
  notes              String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([adminId, year, month])
}

model Patient {
  id                    String       @id @default(cuid())
  firstName             String
  lastName              String       @default("")
  email                 String       @unique
  phone                 String       @default("")
  alignerCount          Int
  pkg                   String       @default("Go") // Express | Go
  videoUrl              String       @default("")
  notes                 String       @default("")
  // draft | sent | interested | awaiting | deposit | paid | overdue
  status                String       @default("draft")
  pricePence            Int
  discountPct           Int          @default(5)
  amountPaidPence       Int          @default(0)
  // £250 consultation/booking paid before the proposal — deducted from the total.
  upfrontPaidPence      Int          @default(0)
  // ── 7-touch follow-up sequence ──
  // proposalSentAt is the clock: touches fire on days 1,4,10,20,26,29,30 after it.
  // The quoted price is locked for 30 days from this date.
  proposalSentAt        DateTime?
  sequenceTouch         Int          @default(0) // highest touch sent (0 = none, 7 = done)
  priceLockExpired      Boolean      @default(false) // set at day 30 — admin should requote
  // Which coordinator the proposal was sent from (emails come from / are signed by them)
  sentByName            String       @default("")
  sentByEmail           String       @default("")
  // Owning admin — plain admins only see patients they own (or sent); null = legacy,
  // visible to Super Admins only.
  ownerId               String?
  owner                 Admin?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // Consent & finance application (captured when patient applies for finance / registers interest)
  dateOfBirth           String       @default("")
  consentSignedAt       DateTime?
  consentSignature      String? // data-URL PNG of the drawn signature
  financeLink           String       @default("") // finance/info link the admin attaches
  financeApprovedAt     DateTime?
  // External finance track — persists independently of payment status so the
  // Finance filter/badge never disappears when they later pay by card.
  // none | applied | accepted | declined
  financeStatus         String       @default("none")
  proposalToken         String       @unique @default(cuid())
  passwordHash          String? // set on first visit to the secure link
  otpHash               String? // hashed one-time login code
  otpExpiresAt          DateTime?
  otpAttempts           Int          @default(0)
  // Patient's chosen payment route: full | deposit | monthly | finance
  paymentPreference     String?
  stripeCustomerId      String?
  stripePaymentMethodId String? // saved card for scheduled instalments
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  activities            Activity[]
  payments              Payment[]
  instalments           Instalment[]
  uploads               PatientUpload[]
}

/// Files attached to a patient proposal (by patient or admin). Stored as
/// base64 so we don't need Blob storage for the first release — capped at 2MB.
model PatientUpload {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String
  sizeBytes  Int
  dataBase64 String
  // patient | admin
  uploadedBy String   @default("patient")
  createdAt  DateTime @default(now())

  @@index([patientId, createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([patientId, createdAt])
}

model Payment {
  id                    String    @id @default(cuid())
  patientId             String
  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  amountPence           Int
  type                  String // full | deposit | instalment | manual
  status                String    @default("pending") // pending | paid | failed
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  @@index([patientId])
}

model Instalment {
  id                    String    @id @default(cuid())
  patientId             String
  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  number                Int // 1..3
  amountPence           Int
  dueDate               DateTime
  status                String    @default("scheduled") // scheduled | paid | failed
  stripePaymentIntentId String?
  paidAt                DateTime?
  // Pre-charge reminder email (sent ~3 days before dueDate)
  reminderSentAt        DateTime?
  createdAt             DateTime  @default(now())

  @@index([patientId])
  @@index([status, dueDate])
}
