# ── Core ────────────────────────────────────────────────────────────────
# REMOTE POSTGRES ONLY — copy Production values from Vercel → Settings → Environment Variables.
# Local dev and production share the same database.
# On Vercel with the Supabase integration you can leave this unset: the app
# falls back to POSTGRES_PRISMA_URL / POSTGRES_URL automatically. Set it here
# for local dev (use the session-pooler / non-pooling URL, port 5432).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Long random string — used to sign login session cookies. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Public URL of the app (local dev can still use localhost; proposal links use this in emails)
APP_URL="http://localhost:3000"

# ── Stripe (dashboard.stripe.com → Developers → API keys) ──────────────
STRIPE_SECRET_KEY="sk_test_..."
# From Dashboard → Webhooks endpoint secret (production)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email ─────────────────────────────────────────────────────────────
# Primary sender is Gmail (see the Google OAuth block at the bottom). Resend is
# an optional fallback used only when Gmail isn't configured. EMAIL_FROM must be
# the authorised Gmail mailbox (or a verified send-as alias on it).
RESEND_API_KEY=""
EMAIL_FROM="Dental Scotland <concierge@dentalscotland.com>"

# ── WhatsApp Business Cloud API ─────────────────────────────────────────
# Preferred: configure in Admin → WhatsApp (Super Admin). Values are stored in
# the shared DB and apply to local + production. Env vars below are optional fallbacks.
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_TEMPLATES_ENABLED="1"
# WHATSAPP_TEMPLATE_LANG="en_GB"
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# META_APP_SECRET=""
# Callback URL (Meta → WhatsApp → Configuration):
#   https://dashboard.dentalscotland.com/api/whatsapp/webhook
# Local-only: set ALLOW_DEV_OTP=1 to show OTP on-screen when mail/WhatsApp keys are missing.
# ALLOW_DEV_OTP="1"
# Do NOT set ALLOW_PRODUCTION_SEED on Vercel — the seed API is blocked in production.

# ── Practice / notifications ────────────────────────────────────────────
ADMIN_NOTIFY_EMAIL="concierge@dentalscotland.com"
# Practice number to receive alerts, E.164 format e.g. +447700900123
ADMIN_NOTIFY_WHATSAPP=""

# ── Finance & pricing ───────────────────────────────────────────────────
FINANCE_APPLY_URL="https://your-finance-provider.example.com/apply"
PAY_DISCOUNT_PCT="5"

# ── Cron (protects instalment collection + live seed endpoint) ───────────
CRON_SECRET="change-me-too"

# ── Gmail send (Google Cloud OAuth; scope gmail.send) ────────────────────
# Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application).
# Authorized redirect URI: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Obtained once by visiting /api/auth/google as an admin (leave blank until then).
GMAIL_REFRESH_TOKEN=""
